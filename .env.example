# =============================================================================
# TelemetryFlow Agent - Environment Variables
# =============================================================================
# Copy this file to .env and update the values as needed
# =============================================================================

# -----------------------------------------------------------------------------
# Build Configuration
# -----------------------------------------------------------------------------
VERSION=1.0.0
GIT_COMMIT=unknown
GIT_BRANCH=main
BUILD_TIME=unknown

# -----------------------------------------------------------------------------
# Container Configuration
# -----------------------------------------------------------------------------
CONTAINER_NAME=tfo-agent
IMAGE_NAME=telemetryflow/tfo-agent
IMAGE_TAG=1.0.0

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# OTLP gRPC receiver port
OTLP_GRPC_PORT=4317

# OTLP HTTP receiver port
OTLP_HTTP_PORT=4318

# Prometheus metrics port (self-observability)
METRICS_PORT=8888

# Health check port
HEALTH_PORT=13133

# -----------------------------------------------------------------------------
# TelemetryFlow API Configuration
# -----------------------------------------------------------------------------
TELEMETRYFLOW_API_ENDPOINT=http://localhost:3100
TELEMETRYFLOW_API_KEY_ID=your-api-key-id
TELEMETRYFLOW_API_KEY_SECRET=your-api-key-secret

# -----------------------------------------------------------------------------
# Collector Endpoint (where agent sends telemetry)
# -----------------------------------------------------------------------------
COLLECTOR_ENDPOINT=http://tfo-collector:4317
COLLECTOR_INSECURE=true

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
AGENT_HOSTNAME=
AGENT_DESCRIPTION=TelemetryFlow Agent

# Heartbeat interval
HEARTBEAT_INTERVAL=30s
HEARTBEAT_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Buffer Configuration
# -----------------------------------------------------------------------------
BUFFER_ENABLED=true
BUFFER_PATH=/var/lib/tfo-agent/buffer
BUFFER_MAX_SIZE_MB=100

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
MEMORY_LIMIT=512M
CPU_LIMIT=0.5
