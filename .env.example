# =============================================================================
# TelemetryFlow Agent - Environment Variables
# =============================================================================
# Copy this file to .env and update the values as needed
# =============================================================================

# -----------------------------------------------------------------------------
# Build Configuration
# -----------------------------------------------------------------------------
VERSION=1.1.1
OTEL_SDK_VERSION=1.39.0
GIT_COMMIT=unknown
GIT_BRANCH=main
BUILD_TIME=unknown

# -----------------------------------------------------------------------------
# Container Configuration
# -----------------------------------------------------------------------------
CONTAINER_NAME=tfo-agent
IMAGE_NAME=telemetryflow/telemetryflow-agent
IMAGE_TAG=1.1.1

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# OTLP gRPC receiver port
OTLP_GRPC_PORT=4317

# OTLP HTTP receiver port
OTLP_HTTP_PORT=4318

# Prometheus metrics port (self-observability)
METRICS_PORT=8888

# Health check port
HEALTH_PORT=13133

# -----------------------------------------------------------------------------
# TelemetryFlow API Configuration
# -----------------------------------------------------------------------------
TELEMETRYFLOW_API_ENDPOINT=http://localhost:3100
TELEMETRYFLOW_API_KEY_ID=your-api-key-id
TELEMETRYFLOW_API_KEY_SECRET=your-api-key-secret

# -----------------------------------------------------------------------------
# Collector Endpoint (where agent sends telemetry)
# -----------------------------------------------------------------------------
COLLECTOR_ENDPOINT=http://tfo-collector:4317
COLLECTOR_INSECURE=true

# -----------------------------------------------------------------------------
# Agent Configuration
# -----------------------------------------------------------------------------
AGENT_HOSTNAME=
AGENT_DESCRIPTION=TelemetryFlow Agent

# Heartbeat interval
HEARTBEAT_INTERVAL=30s
HEARTBEAT_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Buffer Configuration
# -----------------------------------------------------------------------------
BUFFER_ENABLED=true
BUFFER_PATH=/var/lib/tfo-agent/buffer
BUFFER_MAX_SIZE_MB=100

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
MEMORY_LIMIT=512M
CPU_LIMIT=0.5

# =============================================================================
# Integration Configurations
# =============================================================================

# -----------------------------------------------------------------------------
# Cloud Provider Integrations
# -----------------------------------------------------------------------------

# GCP Integration
GCP_ENABLED=false
GCP_PROJECT_ID=
GCP_CREDENTIALS_FILE=
GCP_REGION=us-central1
GCP_METRIC_PREFIX=custom.googleapis.com/telemetryflow
GCP_LOG_NAME=telemetryflow
GCP_MONITORING_ENDPOINT=https://monitoring.googleapis.com/v3
GCP_LOGGING_ENDPOINT=https://logging.googleapis.com/v2
GCP_TRACE_ENDPOINT=https://cloudtrace.googleapis.com/v2

# Azure Integration
AZURE_ENABLED=false
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REGION=eastus
AZURE_WORKSPACE_ID=
AZURE_WORKSPACE_KEY=
AZURE_INSTRUMENTATION_KEY=

# Alibaba Cloud Integration
ALIBABA_ENABLED=false
ALIBABA_REGION_ID=cn-hangzhou
ALIBABA_ACCESS_KEY_ID=
ALIBABA_ACCESS_KEY_SECRET=
ALIBABA_NAMESPACE=acs_custom
ALIBABA_PROJECT=
ALIBABA_LOGSTORE=

# AWS CloudWatch Integration
CLOUDWATCH_ENABLED=false
CLOUDWATCH_REGION=us-east-1
CLOUDWATCH_ACCESS_KEY_ID=
CLOUDWATCH_SECRET_ACCESS_KEY=
CLOUDWATCH_NAMESPACE=TelemetryFlow
CLOUDWATCH_LOG_GROUP=/telemetryflow/agent
CLOUDWATCH_LOG_STREAM=

# -----------------------------------------------------------------------------
# Observability Platform Integrations
# -----------------------------------------------------------------------------

# Prometheus Integration
PROMETHEUS_ENABLED=false
PROMETHEUS_ENDPOINT=http://localhost:9090/api/v1/write
PROMETHEUS_JOB_NAME=telemetryflow-agent
PROMETHEUS_TIMEOUT=30s

# Datadog Integration
DATADOG_ENABLED=false
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
DATADOG_SERVICE=telemetryflow
DATADOG_ENV=production

# Splunk Integration
SPLUNK_ENABLED=false
SPLUNK_HEC_ENDPOINT=
SPLUNK_HEC_TOKEN=
SPLUNK_INDEX=main
SPLUNK_SOURCE=telemetryflow
SPLUNK_SOURCETYPE=_json

# Elasticsearch Integration
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_ADDRESSES=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=telemetryflow

# InfluxDB Integration
INFLUXDB_ENABLED=false
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=
INFLUXDB_BUCKET=telemetryflow

# Loki Integration
LOKI_ENABLED=false
LOKI_ENDPOINT=http://localhost:3100
LOKI_TENANT_ID=
LOKI_BATCH_SIZE=100

# Jaeger Integration
JAEGER_ENABLED=false
JAEGER_COLLECTOR_ENDPOINT=http://localhost:14268/api/traces
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Zipkin Integration
ZIPKIN_ENABLED=false
ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans

# New Relic Integration
NEWRELIC_ENABLED=false
NEWRELIC_LICENSE_KEY=
NEWRELIC_REGION=US
NEWRELIC_SERVICE_NAME=telemetryflow
NEWRELIC_ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Infrastructure Integrations
# -----------------------------------------------------------------------------

# Proxmox Integration
PROXMOX_ENABLED=false
PROXMOX_API_URL=
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
PROXMOX_TLS_SKIP_VERIFY=false

# VMware vCenter Integration
VMWARE_ENABLED=false
VMWARE_VCENTER_URL=
VMWARE_USERNAME=
VMWARE_PASSWORD=
VMWARE_DATACENTER=
VMWARE_TLS_SKIP_VERIFY=false

# Nutanix Integration
NUTANIX_ENABLED=false
NUTANIX_PRISM_URL=
NUTANIX_USERNAME=
NUTANIX_PASSWORD=
NUTANIX_CLUSTER_UUID=

# Azure Arc Integration
AZUREARC_ENABLED=false
AZUREARC_SUBSCRIPTION_ID=
AZUREARC_RESOURCE_GROUP=
AZUREARC_TENANT_ID=
AZUREARC_CLIENT_ID=
AZUREARC_CLIENT_SECRET=
AZUREARC_USE_MANAGED_IDENTITY=false

# Telegraf Integration
TELEGRAF_ENABLED=false
TELEGRAF_ADDRESS=http://localhost:8186
TELEGRAF_PROTOCOL=http
TELEGRAF_DATABASE=telegraf
TELEGRAF_PRECISION=ns

# Percona PMM Integration
PERCONA_ENABLED=false
PERCONA_SERVER_URL=
PERCONA_API_KEY=
PERCONA_USERNAME=
PERCONA_PASSWORD=

# -----------------------------------------------------------------------------
# Messaging Integrations
# -----------------------------------------------------------------------------

# MQTT Integration
MQTT_ENABLED=false
MQTT_BROKER=tcp://localhost:1883
MQTT_CLIENT_ID=tfo-agent
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_METRICS_TOPIC=telemetryflow/metrics
MQTT_LOGS_TOPIC=telemetryflow/logs
MQTT_TRACES_TOPIC=telemetryflow/traces

# Kafka Integration
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_METRICS_TOPIC=telemetryflow-metrics
KAFKA_LOGS_TOPIC=telemetryflow-logs
KAFKA_TRACES_TOPIC=telemetryflow-traces
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Webhook Integration
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_METHOD=POST
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT=30s
WEBHOOK_RETRY_COUNT=3

# -----------------------------------------------------------------------------
# Network Integrations
# -----------------------------------------------------------------------------

# Cisco DNA Center Integration
CISCO_ENABLED=false
CISCO_API_TYPE=dnac
CISCO_DNAC_URL=
CISCO_USERNAME=
CISCO_PASSWORD=

# SNMP Integration
SNMP_ENABLED=false
SNMP_TARGETS=
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Additional Integrations
# -----------------------------------------------------------------------------

# Alloy (Grafana Agent) Integration
ALLOY_ENABLED=false
ALLOY_ENDPOINT=http://localhost:4318
ALLOY_TENANT_ID=

# Blackbox Exporter Integration
BLACKBOX_ENABLED=false
BLACKBOX_ENDPOINT=http://localhost:9115
BLACKBOX_TARGETS=
